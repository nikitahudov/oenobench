\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Per-domain accuracy as a heatmap. \emph  {Wine business} is the hardest domain across every tier (mean 56.5\%) — both because business-domain facts are sparser in the training distribution and because the C4 difficulty re-label promoted business questions that are computationally harder (multi-fact reasoning over regulation).}}{21}{figure.9}\protected@file@percent }
\newlabel{fig:domain-heatmap}{{9}{21}{Per-domain accuracy as a heatmap. \emph {Wine business} is the hardest domain across every tier (mean 56.5\%) — both because business-domain facts are sparser in the training distribution and because the C4 difficulty re-label promoted business questions that are computationally harder (multi-fact reasoning over regulation)}{figure.9}{}}
