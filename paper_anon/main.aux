\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Per-strategy accuracy heatmap. Templates are the easiest strategy uniformly (89.5\% mean), even for small models, because they are deterministic single-fact recall questions. The fact-to-question strategy is hardest because its distractors are sampled from confusable same-category entities; comparative questions add the constraint that the model must integrate two facts.}}{22}{figure.10}\protected@file@percent }
\newlabel{fig:strategy-heatmap}{{10}{22}{Per-strategy accuracy heatmap. Templates are the easiest strategy uniformly (89.5\% mean), even for small models, because they are deterministic single-fact recall questions. The fact-to-question strategy is hardest because its distractors are sampled from confusable same-category entities; comparative questions add the constraint that the model must integrate two facts}{figure.10}{}}
