# =============================================================================
# WineBench Infrastructure — Environment Configuration
# Copy this file: cp .env.example .env
# Then fill in passwords and adjust settings as needed.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=winebench
POSTGRES_USER=winebench
POSTGRES_PASSWORD=CHANGE_ME_pg_secure_password_here
POSTGRES_PORT=5432

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ES_PORT=9200

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_secure_password_here
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_secure_password_here
REDIS_PORT=6379

# ─── LLM API Keys (used by application, not Docker services) ─────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Application Settings ────────────────────────────────────────────────────
WINEBENCH_ENV=development
LOG_LEVEL=INFO

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_ME_dashboard_password_here
DASHBOARD_PORT=5555
